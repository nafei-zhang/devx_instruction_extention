{
  "name": "vscode-github-file-puller",
  "displayName": "GitHub File Puller",
  "description": "Fetch one or more specific files from a GitHub repository into a target folder in your workspace. Supports private repositories (token auth), conflict strategies, folder structure preservation, and encoding detection.",
  "version": "0.1.5",
  "publisher": "your-publisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-publisher/vscode-github-file-puller"
  },
  "homepage": "https://github.com/your-publisher/vscode-github-file-puller",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "license": "MIT",
  "activationEvents": [
    "onCommand:githubPuller.fetchFiles",
    "onCommand:githubPuller.runAutoSync",
    "onCommand:githubPuller.configureToken",
    "onCommand:githubPuller.setToken",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "githubPuller.fetchFiles",
        "title": "GitHub: Open Puller Config"
      },
      {
        "command": "githubPuller.setToken",
        "title": "GitHub: Set Token (Secret Storage)"
      },
      {
        "command": "githubPuller.configureToken",
        "title": "GitHub: Puller Configure Token"
      },
      {
        "command": "githubPuller.runAutoSync",
        "title": "GitHub: Run Puller Auto Sync"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "GitHub File Puller",
      "properties": {
        "githubPuller.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar button to run Puller auto sync."
        },
        "githubPuller.defaultTargetDir": {
          "type": "string",
          "default": "",
          "description": "Legacy single default target directory. Automatically synced to the first entry in githubPuller.targetDirs."
        },
        "githubPuller.targetDirs": {
          "type": "string",
          "default": "",
          "description": "Comma-separated absolute target directories. Example: /path/a,/path/b"
        },
        "githubPuller.conflictResolution": {
          "type": "string",
          "enum": ["overwrite", "skip", "rename"],
          "default": "rename",
          "description": "File conflict strategy: overwrite, skip, or rename."
        },
        "githubPuller.preserveStructure": {
          "type": "boolean",
          "default": true,
          "description": "Preserve the repository folder structure in the workspace."
        },
        "githubPuller.baseUrl": {
          "type": "string",
          "default": "https://alm-github.com.hsbc/",
          "description": "Base URL for GitHub or GitHub Enterprise (e.g., https://github.example.com)."
        },
        "githubPuller.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional API base URL (e.g., https://github.example.com/api/v3). If empty: uses https://api.github.com when baseUrl is https://github.com; otherwise defaults to baseUrl + /api/v3."
        },
        "githubPuller.defaultRef": {
          "type": "string",
          "default": "main",
          "description": "Default branch or tag (ref)."
        },
        "githubPuller.syncRepoUrl": {
          "type": "string",
          "default": "https://github.com/SebastienDegodez/copilot-instructions",
          "description": "Repository URL used by Puller auto sync."
        },
        "githubPuller.syncRef": {
          "type": "string",
          "default": "main",
          "description": "Branch/tag used by Puller auto sync."
        },
        "githubPuller.syncPaths": {
          "type": "string",
          "default": "instructions,scripts,skills",
          "description": "Comma-separated repository files/folders to sync."
        },
        "githubPuller.token": {
          "type": "string",
          "default": "",
          "description": "Fallback token (not recommended; stored in plaintext). Prefer the \"GitHub: Set Token (Secret Storage)\" command."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "typecheck": "tsc -p . --noEmit",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js",
    "package:vsix": "npm run compile && vsce package",
    "package": "npm run package:vsix"
  },
  "devDependencies": {
    "@types/node": "^20.11.10",
    "@types/node-fetch": "^2.6.4",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "@types/mocha": "^10.0.1",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "glob": "^10.3.10",
    "@types/glob": "^8.1.0",
    "@vscode/vsce": "^3.0.0"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3",
    "istextorbinary": "^6.0.0",
    "chardet": "^2.0.0",
    "node-fetch": "^2.7.0"
  }
}
